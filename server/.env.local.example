# Copy this file to .env.local and fill in your actual credentials
# .env.local is gitignored and should NOT be committed

DB_URL=mongodb://localhost:27017/movie
PORT=3001

# Cloudinary credentials (get from https://cloudinary.com)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_KEY=your_cloudinary_key
CLOUDINARY_SECRET=your_cloudinary_secret

# Gmail credentials (enable 2FA and use app password)
GMAIL_EMAIL=your_email@gmail.com
GMAIL_PASSWORD=your_app_password
